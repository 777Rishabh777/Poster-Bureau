{
  "version": 2,
  "functions": {
    "server-node/server.js": {
      "includeFiles": "{client/**,server-node/data/**}"
    }
  },
  "builds": [
    {
      "src": "server-node/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server-node/server.js"
    }
  ]
}